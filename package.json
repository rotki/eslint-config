  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rotki/eslint-config.git"
  },
  "author": "Rotki Solutions GmbH <info@rotki.com>",
  "files": [
    "dist"
  ],
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs"
  },
  "scripts": {
    "build": "pnpm run gen && tsdown --clean --dts",
    "stub": "tsdown",
    "dev": "tsdown --watch & npx @eslint/config-inspector --config eslint.config.ts",
    "watch": "tsdown --watch",
    "lint": "eslint .",
    "prepack": "pnpm run build",
    "release": "bumpp -r --no-push",
    "prepare": "husky",
    "gen": "tsx scripts/typegen.ts",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@intlify/eslint-plugin-vue-i18n": "^4.0.0",
